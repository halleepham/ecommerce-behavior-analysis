# --- Data files (NEVER commit these) ---
# Block all CSVs and data files by default
*.csv
*.parquet
*.json
*.zip

# Explicitly allow the sample files in data/raw/ and data/processed/
!data/raw/oct_sample.csv
!data/raw/nov_sample.csv
!data/processed/events_clean.csv

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/

# --- Virtual environments ---
venv/
env/
.venv/

# --- Environment & secrets ---
.env

# --- Kaggle notebooks checkpoints ---
.ipynb_checkpoints/

# --- OS files ---
.DS_Store
Thumbs.db

# --- IDE files ---
.vscode/

# --- Test and coverage artifacts ---
.pytest_cache/
.coverage
htmlcov/